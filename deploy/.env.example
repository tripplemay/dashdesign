# Copy to `.env` and fill in. NEVER commit the real .env (it holds secrets).
# Generate strong random values, e.g.:  openssl rand -base64 24

# --- required ---
DB_PASSWORD=change-me-strong-random
BASELINE_ADMIN_TOKEN=change-me-strong-random-admin-token

# --- document storage ---
# 'local' keeps uploads on the docdata volume (fine for one ECS box).
# 'oss' stores them in Aliyun OSS (durable, multi-node) — fill the block below.
BASELINE_DOC_STORE=local
# BASELINE_OSS_BUCKET=my-baseline-bucket
# Use the INTERNAL endpoint when the ECS box and bucket are in the same region
# (free traffic), e.g. oss-cn-hangzhou-internal.aliyuncs.com
# BASELINE_OSS_ENDPOINT=oss-cn-hangzhou-internal.aliyuncs.com
# ALIBABA_CLOUD_ACCESS_KEY_ID=
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=

# --- server-side merge jobs (optional) ---
# Only needed if you use POST /merge-jobs on the server. The desktop app's merge
# flow parses locally and just saves the resulting draft, so this can stay empty.
# OPENAI_BASE_URL=https://your-gateway/v1
# OPENAI_API_KEY=
# DASHDESIGN_BASELINE_MODEL=gpt-4o

# --- TLS (used only with `--profile tls`) ---
# A-record for this name must point at the ECS public IP; open ports 80 + 443.
SITE_DOMAIN=baseline.example.com
