{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dashdesign.local/schemas/baseline.schema.json",
  "title": "DashDesign Project Baseline",
  "description": "Versioned project baseline for cloud-synchronized, audience-aware image generation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "baseline_id",
    "version",
    "status",
    "target_audience_mode",
    "source_documents",
    "project",
    "source_facts",
    "audience_transform_rules",
    "consumer_baseline",
    "visual_guidelines",
    "prompt_policy",
    "evidence_index",
    "governance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "baseline_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{2,80}$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]{4}\\.[0-9]{2}\\.[0-9]{2}\\.[0-9]+$"
    },
    "parent_version": {
      "type": ["string", "null"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "published", "archived"]
    },
    "target_audience_mode": {
      "type": "string",
      "enum": ["to_c_parent_student", "to_b_partnership", "internal"]
    },
    "source_context": {
      "type": "string",
      "enum": ["to_b_partnership_docs", "to_c_marketing_docs", "mixed_docs", "manual"]
    },
    "source_documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_document"
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "aliases", "category", "core_positioning", "business_context"],
      "properties": {
        "name": {"type": "string"},
        "aliases": {"type": "array", "items": {"type": "string"}},
        "category": {"type": "array", "items": {"type": "string"}},
        "core_positioning": {"$ref": "#/$defs/evidenced_text"},
        "business_context": {"$ref": "#/$defs/evidenced_text"}
      }
    },
    "source_facts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_audience",
        "course_system",
        "education_values",
        "business_terms",
        "consumer_safe_facts"
      ],
      "properties": {
        "raw_audience": {
          "type": "object",
          "additionalProperties": false,
          "required": ["b_side_customers", "decision_makers", "end_users"],
          "properties": {
            "b_side_customers": {"type": "array", "items": {"$ref": "#/$defs/evidenced_text"}},
            "decision_makers": {"type": "array", "items": {"$ref": "#/$defs/evidenced_text"}},
            "end_users": {"type": "array", "items": {"$ref": "#/$defs/evidenced_text"}}
          }
        },
        "course_system": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/course_module"}
        },
        "education_values": {
          "type": "array",
          "items": {"$ref": "#/$defs/evidenced_text"}
        },
        "business_terms": {
          "type": "array",
          "description": "B-side cooperation and institution-operation content. This is retained for traceability but must not enter to-C image prompts directly.",
          "items": {"$ref": "#/$defs/evidenced_text"}
        },
        "consumer_safe_facts": {
          "type": "array",
          "description": "Facts that can be safely transformed into to-C parent/student messaging.",
          "items": {"$ref": "#/$defs/evidenced_text"}
        }
      }
    },
    "audience_transform_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "preserve", "rewrite", "remove", "gating_rule"],
      "properties": {
        "from": {"type": "string"},
        "to": {"type": "string", "const": "to_c_parent_student"},
        "preserve": {"type": "array", "items": {"type": "string"}},
        "rewrite": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_concept", "target_expression"],
            "properties": {
              "source_concept": {"type": "string"},
              "target_expression": {"type": "string"}
            }
          }
        },
        "remove": {"type": "array", "items": {"type": "string"}},
        "gating_rule": {"type": "string"}
      }
    },
    "consumer_baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audience",
        "positioning",
        "core_messages",
        "parent_value",
        "student_value",
        "course_modules",
        "allowed_keywords",
        "blocked_keywords",
        "claims_policy"
      ],
      "properties": {
        "audience": {
          "type": "object",
          "additionalProperties": false,
          "required": ["primary_decision_maker", "end_user", "secondary_audience"],
          "properties": {
            "primary_decision_maker": {"type": "string"},
            "end_user": {"type": "string"},
            "secondary_audience": {"type": "array", "items": {"type": "string"}}
          }
        },
        "positioning": {"$ref": "#/$defs/evidenced_text"},
        "core_messages": {"type": "array", "items": {"$ref": "#/$defs/evidenced_text"}},
        "parent_value": {"type": "array", "items": {"$ref": "#/$defs/evidenced_text"}},
        "student_value": {"type": "array", "items": {"$ref": "#/$defs/evidenced_text"}},
        "course_modules": {"type": "array", "items": {"type": "string"}},
        "allowed_keywords": {"type": "array", "items": {"type": "string"}},
        "blocked_keywords": {"type": "array", "items": {"type": "string"}},
        "claims_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allowed", "requires_review", "forbidden"],
          "properties": {
            "allowed": {"type": "array", "items": {"type": "string"}},
            "requires_review": {"type": "array", "items": {"type": "string"}},
            "forbidden": {"type": "array", "items": {"type": "string"}}
          }
        }
      }
    },
    "visual_guidelines": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "style_keywords",
        "recommended_subjects",
        "recommended_scenes",
        "composition_rules",
        "avoid_scenes",
        "text_generation_policy"
      ],
      "properties": {
        "style_keywords": {"type": "array", "items": {"type": "string"}},
        "recommended_subjects": {"type": "array", "items": {"type": "string"}},
        "recommended_scenes": {"type": "array", "items": {"type": "string"}},
        "composition_rules": {"type": "array", "items": {"type": "string"}},
        "avoid_scenes": {"type": "array", "items": {"type": "string"}},
        "text_generation_policy": {"type": "string"}
      }
    },
    "prompt_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system_context",
        "positive_prompt_template",
        "negative_constraints",
        "injection_order"
      ],
      "properties": {
        "system_context": {"type": "string"},
        "positive_prompt_template": {"type": "string"},
        "negative_constraints": {"type": "array", "items": {"type": "string"}},
        "injection_order": {"type": "array", "items": {"type": "string"}}
      }
    },
    "evidence_index": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/evidence"}
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["draft_policy", "publish_policy", "generation_record_policy"],
      "properties": {
        "draft_policy": {"type": "string"},
        "publish_policy": {"type": "string"},
        "generation_record_policy": {"type": "string"}
      }
    },
    "unmapped_findings": {
      "type": "array",
      "description": "Extracted content that did not safely fit the current schema and needs human review.",
      "items": {"$ref": "#/$defs/evidenced_text"}
    }
  },
  "$defs": {
    "source_document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document_id", "file", "type", "role", "status"],
      "properties": {
        "document_id": {"type": "string"},
        "file": {"type": "string"},
        "type": {"type": "string"},
        "role": {"type": "string"},
        "status": {"type": "string", "enum": ["active", "duplicate", "archived"]}
      }
    },
    "evidenced_text": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "evidence"],
      "properties": {
        "text": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "evidence": {
          "type": "array",
          "items": {"type": "string"}
        },
        "notes": {"type": "string"}
      }
    },
    "course_module": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "description", "student_outcomes", "evidence"],
      "properties": {
        "id": {"type": "string"},
        "name": {"type": "string"},
        "description": {"type": "string"},
        "student_outcomes": {"type": "array", "items": {"type": "string"}},
        "evidence": {"type": "array", "items": {"type": "string"}}
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "document_id", "section", "quote"],
      "properties": {
        "id": {"type": "string"},
        "document_id": {"type": "string"},
        "section": {"type": "string"},
        "quote": {"type": "string"}
      }
    }
  }
}
